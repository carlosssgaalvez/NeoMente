{
  "expo": {
    "name": "NeoMente",
    "slug": "neomente",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#1B5E20"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.carlos.neomente"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B5E20"
      },
      "package": "com.carlos.neomente"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-localization",
      "expo-asset",
      "expo-secure-store",
      "expo-notifications",
      "expo-sqlite"
    ],
    "extra": {
      "apiUrl": "https://neomente-backend.onrender.com"
    }
  }
}
